# =============================================================================
# Supabase -> GCP migration configuration
# Copy to gcp/.env.migration and fill in. All scripts in gcp/scripts source this.
# Keep this file OUT of git (see gcp/.gitignore). Never commit real secrets.
# =============================================================================

# ---- GCP project / location (India residency) ------------------------------
export PROJECT_ID="your-gcp-project-id"
export REGION="asia-south1"            # Mumbai. Alt: asia-south2 (Delhi)
export ZONE="asia-south1-a"

# Naming (override if you like)
export VPC_NAME="aczen-vpc"
export SUBNET_NAME="aczen-subnet"
export CONNECTOR_NAME="aczen-conn"        # Serverless VPC Access connector
export AR_REPO="aczen"                    # Artifact Registry repo
export SQL_INSTANCE="aczen-pg"            # Cloud SQL instance id
export SQL_DB="postgres"                  # application database name
export SQL_TIER="db-custom-2-7680"        # 2 vCPU / 7.5 GB; size to your load
export SQL_PG_VERSION="POSTGRES_16"

# ---- Cloud SQL passwords (generate strong values) --------------------------
# postgres = superuser; authenticator = role PostgREST logs in as.
export SQL_ROOT_PASSWORD="change-me-postgres-superuser"
export AUTHENTICATOR_PASSWORD="change-me-authenticator"

# ---- Source Supabase (for data migration) ----------------------------------
# Get the pooler/direct connection string from Supabase dashboard:
#   Project Settings -> Database -> Connection string (URI, "direct").
export SUPABASE_DB_URL="postgresql://postgres:[PWD]@db.vhntnkvtzmerpdhousfr.supabase.co:5432/postgres"
export SUPABASE_PROJECT_REF="vhntnkvtzmerpdhousfr"

# ---- JWT / auth (Clerk stays the IdP) ---------------------------------------
# PostgREST validates every JWT against a SINGLE secret. Your Clerk "supabase"
# JWT template is already signed with the Supabase project's HS256 JWT secret,
# so set PGRST_JWT_SECRET to that SAME secret and existing user tokens validate
# unchanged (zero Clerk change needed at cutover). We then self-mint the
# server-side service_role / anon tokens with the same secret.
#   Find it: Supabase Dashboard -> Project Settings -> API -> "JWT Secret".
export PGRST_JWT_SECRET="paste-your-current-supabase-jwt-secret-here"

# Alternative (optional): if you'd rather have PostgREST validate Clerk's native
# RS256 tokens via JWKS, set this and adjust postgrest/postgrest.conf.template to
# point PGRST_JWT_SECRET at the JWKS. Note: you then cannot self-mint HS256
# service tokens; backends must obtain Clerk machine tokens instead.
export CLERK_JWKS_URL="https://YOUR-clerk-subdomain.clerk.accounts.dev/.well-known/jwks.json"

# These get generated by scripts/mint-jwt.mjs and pushed to Secret Manager.
# Leave blank; they are filled in after minting.
export SERVICE_ROLE_JWT=""
export ANON_JWT=""

# ---- Public URLs (filled in after Cloud Run deploys) ------------------------
export GATEWAY_URL=""        # e.g. https://aczen-gateway-xxxx.a.run.app
export POSTGREST_URL=""      # internal/private URL of PostgREST service
export STORAGE_SHIM_URL=""   # internal URL of storage shim
export APP_URL="https://app.aczen.in"
export PUBLIC_APP_URL="https://app.aczen.in"

# ---- Cloud Storage ----------------------------------------------------------
export GCS_BUCKET="${PROJECT_ID}-aczen-storage"

# ---- Application / third-party secrets (pushed to Secret Manager) -----------
# Fill with the same values currently set via `supabase secrets set ...`.
export LOVABLE_API_KEY=""
export GEMINI_API_KEY=""
export MISTRAL_API_KEY=""
export MISTRAL_API_URL="https://api.mistral.ai/v1/chat/completions"
export MISTRAL_MODEL="mistral-medium"

export RAZORPAY_MODE="live"
export RAZORPAY_KEY_ID=""
export RAZORPAY_KEY_SECRET=""
export RAZORPAY_PARTNER_CLIENT_ID=""
export RAZORPAY_PARTNER_CLIENT_SECRET=""
export RAZORPAY_WEBHOOK_SECRET=""

export DIGILOCKER_CLIENT_ID=""
export DIGILOCKER_CLIENT_SECRET=""
export DIGILOCKER_REDIRECT_URI=""

export CASHFREE_CLIENT_ID=""
export CASHFREE_CLIENT_SECRET=""
export CASHFREE_BASE_URL="https://api.cashfree.com"
export CASHFREE_API_VERSION="2022-09-01"

export ACZEN_MCP_API_KEY=""
export MCP_API_KEY=""

# Node server (server/) extras
export SENDGRID_API_KEY=""
export SUPPORT_FROM_EMAIL="no-reply@aczen.in"
export SUPPORT_FROM_NAME="Aczen"
export DECENTRO_CLIENT_ID=""
export DECENTRO_CLIENT_SECRET=""
export DECENTRO_MODULE_SECRET=""
export DECENTRO_PROVIDER_SECRET=""
export DECENTRO_BASE_URL="https://in.staging.decentro.tech"
