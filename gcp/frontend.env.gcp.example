# Frontend build-time env for the GCP cutover.
# Copy to the repo root as `.env.production.local` (Vite picks it up for builds),
# or set these in your hosting provider's build env.
#
# Both Supabase var names map to the same values; the app reads a couple of
# different names across files, so set all of them.

# Point the supabase-js base URL at the GCP gateway (replaces the Supabase URL).
VITE_SUPABASE_URL=https://aczen-gateway-XXXX.a.run.app

# The minted anon JWT (gcp Secret Manager: anon-jwt). Used as the supabase-js
# "anon key". This is a JWT signed with PGRST_JWT_SECRET, role=anon.
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...anon-jwt...
VITE_SUPABASE_ANON_KEY=eyJ...anon-jwt...

# Clerk (unchanged from today).
VITE_CLERK_PUBLISHABLE_KEY=pk_live_or_test_xxx

# Node backend (Federal Bank / Decentro) base URL -> aczen-node-server Cloud Run URL.
# Only set if the app references it via env; otherwise update the hardcoded base.
VITE_DECENTRO_BASE_URL=/decentro
